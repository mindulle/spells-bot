# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_client_id
DISCORD_GUILD_ID=your_guild_id_for_development

# MinIO Configuration
MINIO_ENDPOINT=play.min.io
MINIO_PORT=443
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=your_access_key
MINIO_SECRET_KEY=your_secret_key
MINIO_DEFAULT_BUCKET=sonagi-bucket

# Eagle Gallery API (Optional)
EAGLE_API_URL=http://localhost:41595/api

# n8n DevOps Webhooks (Optional)
N8N_HEALTH_WEBHOOK=http://your-n8n-instance:5678/webhook/health

# Bot Configuration
LOG_LEVEL=info
NODE_ENV=development

# Sonagi Playgrounds API (Optional)
PLAYGROUNDS_API_URL=https://sonagi-playgrounds.sonagi-dev.workers.dev

# Web Clip Configuration
WEB_CLIP_CHANNEL_ID=1519250071764336650
N8N_WEBHOOK_URL_WEB_CLIP=

# Paperclip API Configuration
PAPERCLIP_API_URL=http://localhost:3000/api
PAPERCLIP_API_TOKEN=your_paperclip_api_token
PAPERCLIP_COMPANY_ID_MINDULLE=your_paperclip_company_id_mindulle
PAPERCLIP_COMPANY_ID_LIFE=your_paperclip_company_id_life

# Lavalink Configuration
LAVALINK_URL=lava-v4.ajieblogs.com:443
LAVALINK_PASSWORD=https://dsc.gg/ajidevserver
LAVALINK_SECURE=true
